# Copy to .env.local (git-ignored). Never commit real keys.

# ——— Optional cloud (Supabase) ———
# Project Settings → API. Anon key is safe in the browser with RLS.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# ——— Optional live Helper (SpaceXAI / xAI) ———
# Console: https://console.x.ai — model used: grok-4.5
# Base URL: https://api.x.ai/v1
#
# WARNING: Vite prefixes expose this key in the browser bundle.
# Fine for local demos; for public production use a server proxy
# and keep XAI_API_KEY server-side only.
# Without a key, Helper uses built-in scripted coaching (always works).
VITE_XAI_API_KEY=

# Prefer server-side XAI_API_KEY (never VITE_*) with a proxy:
#   Dev:  export XAI_API_KEY=...  then npm run dev  → /api/xai proxies to api.x.ai
#   Netlify: set XAI_API_KEY in site env; /.netlify/functions/xai-proxy
# Optional explicit browser base:
# VITE_XAI_BASE_URL=/api/xai
# VITE_XAI_USE_PROXY=true

# Runtime injection (no rebuild): window.__CC_XAI_API_KEY__ /
# window.__CC_XAI_BASE__ for host pages.

# ——— Optional Figma integration ———
# Get these from https://www.figma.com/settings
VITE_FIGMA_CLIENT_ID=your_figma_client_id
VITE_FIGMA_CLIENT_SECRET=your_figma_client_secret
